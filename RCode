data_dir <- "C:/Users/atulb/Downloads/Data"

sample_folders <- list.dirs(data_dir, recursive = FALSE)

seurat_list <- list()

ensembl <- useEnsembl(biomart = "genes", dataset = "hsapiens_gene_ensembl")

# Loop over each sample folder
for (sample_path in sample_folders) {

  sample_name <- basename(sample_path)
  cat("Processing:", sample_name, "\n")

  files <- list.files(sample_path, full.names = TRUE)
  matrix_file   <- files[grepl("matrix.*\\.mtx", files)]
  features_file <- files[grepl("features.*\\.tsv", files)]
  barcodes_file <- files[grepl("barcodes.*\\.tsv", files)]

  counts <- readMM(gzfile(matrix_file))
  genes  <- read.delim(gzfile(features_file), header = FALSE)
  barcodes <- read.delim(gzfile(barcodes_file), header = FALSE)

  # Map Ensembl IDs to HGNC symbols
  gene_map <- getBM(attributes = c("ensembl_gene_id", "hgnc_symbol"),
                    filters = "ensembl_gene_id",
                    values = genes$V1,
                    mart = ensembl)

  mapped_symbols <- gene_map$hgnc_symbol[match(genes$V1, gene_map$ensembl_gene_id)]
  mapped_symbols[is.na(mapped_symbols) | mapped_symbols == ""] <- genes$V1[is.na(mapped_symbols) | mapped_symbols == ""]
  mapped_symbols <- make.unique(mapped_symbols)

  rownames(counts) <- mapped_symbols
  colnames(counts) <- barcodes$V1

  seurat_obj <- CreateSeuratObject(counts = counts)

  seurat_obj <- NormalizeData(seurat_obj)
  seurat_obj <- FindVariableFeatures(seurat_obj)
  seurat_obj <- ScaleData(seurat_obj)

  seurat_list[[sample_name]] <- seurat_obj

  cat("Number of cells:", ncol(seurat_obj), "\n")
  cat("Number of genes:", nrow(seurat_obj), "\n")
  cat("Cells per cluster (initially all 1 cluster):\n")
  print(table(Idents(seurat_obj)))
  cat("\n------------------------\n")
}

